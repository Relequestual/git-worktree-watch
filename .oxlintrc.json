{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "ignorePatterns": ["node_modules/", ".vscode-test/", "out/", "coverage/", "dist/", "*.vsix"],
  "env": {
    "es2022": true,
    "node": true,
    "mocha": true
  },
  "rules": {
    "curly": "warn",
    "eqeqeq": "warn",
    "no-throw-literal": "warn"
  }
}
