{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "es5",
  "tabWidth": 2,
  "singleQuote": true,
  "bracketSpacing": true,
  "printWidth": 100,
  "semi": true,
  "singleAttributePerLine": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    ".vscode-test/",
    "out/",
    "coverage/",
    "dist/",
    "pnpm-lock.yaml",
    "*.vsix"
  ]
}
